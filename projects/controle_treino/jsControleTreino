//Selecionando elementos

const inputExercise = document.querySelector("#input-exercise");
const btnInput = document.querySelector("#btnInput");
const doneBtn = document.querySelector(".doneBtn");
const deleteBtn = document.querySelector(".delete-btn");
const list = document.querySelector(".list");
const container = document.querySelector(".container");
const btnTermino = document.querySelector("#btn-termino");
const alertBox = document.querySelector("#alertBox");
const doneCount = document.querySelector("#doneCount");

//Adicionando treino
btnInput.addEventListener("click", function (event) {
  event.preventDefault();

  const exerciseText = inputExercise.value;
  const li = document.createElement("li");
  li.classList.add("exercise");

  //retirando possíveis espaços que o usuário colocar
  const texto = inputExercise.value.trim();
  const span = document.createElement("span");
  span.textContent = texto;

  const doneBtn = document.createElement("button");
  doneBtn.classList.add("done-btn");
  doneBtn.innerHTML = '<i class="fa-solid fa-check"></i>';

  const deleteBtn = document.createElement("button");
  deleteBtn.classList.add("delete-btn");
  deleteBtn.innerHTML = '<i class="fa-solid fa-remove"></i>';

  const editButton = document.createElement("button");
  editButton.classList.add("edit-btn");
  editButton.innerHTML = '<i class="fa-solid fa-edit"></i>'

  li.appendChild(span);
  li.appendChild(doneBtn);
  li.appendChild(deleteBtn);
  li.appendChild(editButton);

  //verificando se o input ta vazio

  if (texto === "") {
    alert("O campo não pode ficar vazio!");
    inputExercise.focus();
    return;
  }

  list.appendChild(li); //adiciona o exercicio se o input tiver conteúdo

  inputExercise.value = ""; //limpa o input depois de add
  updateCounter();
});

list.addEventListener("click", function (event) {
  // Se clicou no botão Finalizado
  if (event.target.classList.contains("doneBtn")) {
    const li = event.target.parentElement;
    li.classList.toggle("completed");

    updateCounter();
  }

  // Lançando aviso antes de apagar

  if (event.target.classList.contains("delete-btn")) {
    const confirmDelete = confirm(
      "Tem certeza que deseja eliminar este exercício?",
    );

    if (confirmDelete) {
      const li = event.target.parentElement;
      li.classList.add("removing");

      setTimeout(function () {
        li.remove();
        updateCounter();
        showAlert("Exercício eliminado!");
      }, 300);
    }
  }
});

//Funções

function getWorkoutStatus() {
  const allExercises = document.querySelectorAll(".exercise");
  const completedExercises = document.querySelectorAll(".completed");
  return {
    total: allExercises.length,
    completed: completedExercises.length,
  };
}

function isCompleteWorkout() {
  const allExercises = document.querySelectorAll(".exercise");
  const completedExercises = document.querySelectorAll(".completed");
  return (
    completedExercises.length === allExercises.length && allExercises.length > 0
  );
}

function updateCounter() {
  const status = getWorkoutStatus();
  doneCount.textContent =
    "Exercícios concluídos: " + status.completed + " de " + status.total;
}

//Habilitando mensagem de confirmação em botão de término

btnTermino.addEventListener("click", () => {
  if (isCompleteWorkout()) {
    const confirmTermination = confirm("Parabens!");
  } else {
    const confirmTermination = confirm(
      "Você não completou o treino, deseja encerrar?",
    );

    if (confirmTermination) {
      showAlert("Treino encerrado incompleto!");
    }
  }
});

function showAlert(message) {
  alertBox.textContent = message;
  alertBox.classList.add("show");

  setTimeout(function () {
    alertBox.classList.remove("show");
  }, 3000);
}
