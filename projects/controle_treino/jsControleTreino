btnInput = document.querySelector("#btnInput");
inputExercise = document.querySelector("#input-exercise");
doneBtn = document.querySelector(".doneBtn");
deleteBtn = document.querySelector(".delete-btn");
list = document.querySelector(".list");
container = document.querySelector(".container");
btnTermino = document.querySelector(".btn-termino")

//Eventos
btnInput.addEventListener("click", function (event) {
  event.preventDefault();

  const exerciseText = inputExercise.value;
  const li = document.createElement("li");
  li.classList.add("exercise");
  const texto = inputExercise.value.trim();
  const span = document.createElement("span");
  span.textContent = texto;

  const doneButton = document.createElement("button");
  doneButton.textContent = "Finalizado";
  doneButton.classList.add("doneBtn");

  const deleteButton = document.createElement("button");
  deleteButton.textContent = "Eliminar";
  deleteButton.classList.add("delete-btn");

  li.appendChild(span);
  li.appendChild(doneButton);
  li.appendChild(deleteButton);

  //retirando possíveis espaços que o usuário colocar

  //verificando se o input ta vazio

  if (texto === "") {
    alert("O campo não pode ficar vazio!");
    inputExercise.focus();
    return;
  }

  list.appendChild(li); //adiciona o exercicio se o input tiver conteúdo

  inputExercise.value = ""; //limpa o input depois de add
});

list.addEventListener("click", function (event) {
  // Se clicou no botão Finalizado
  if (event.target.classList.contains("doneBtn")) {
    const li = event.target.parentElement;
    li.classList.toggle("completed");

    updateCounter();
  }

  // Lançando aviso antes de apagar

  if (event.target.classList.contains("delete-btn")) {
    const confirmDelete = confirm(
      "Tem certeza que deseja eliminar este exercício?",
    );

    if (confirmDelete) {
      const li = event.target.parentElement;
      li.classList.add("removing");

      setTimeout(function () {
        li.remove();
        updateCounter();
        showAlert("Exercício eliminado!");
      }, 300);
    }
  }
});

