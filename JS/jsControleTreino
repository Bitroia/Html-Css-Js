list.addEventListener("click", function (event) {

    // Se clicou no botão Finalizado
    if (event.target.classList.contains("doneBtn")) {

        const li = event.target.parentElement;
        li.classList.toggle("completed");

        updateCounter();
    }

    // Lançando aviso antes de apagar

    if (event.target.classList.contains("delete-btn")) {

        const confirmDelete = confirm("Tem certeza que deseja eliminar este exercício?")

        if (confirmDelete) {

            const li = event.target.parentElement
            li.remove()
            updateCounter()

            showAlert("Exercício eliminado!")

        }
    }

});

